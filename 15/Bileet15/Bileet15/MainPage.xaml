<Page x:Class="Bileet15.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Bileet15"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage"
      Background="White">

    <Grid Background="Gray">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="1*"></RowDefinition>
            <RowDefinition Height="3*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Background="Black" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBox Width="250" Height="50" Name="CityFilter" TextChanged="CityFilter_TextChanged"></TextBox>
            <ComboBox Width="250" Height="50" Name="RegionFilter" SelectionChanged="RegionFilter_SelectionChanged" DisplayMemberPath="Title"></ComboBox>
        </StackPanel>

        <StackPanel Background="Black" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBox Width="250" Height="50" Name="Populationfilter" TextChanged="Populationfilter_TextChanged"></TextBox>
            <ComboBox Width="250" Height="50" Name="OkrugFilter" SelectionChanged="OkrugFilter_SelectionChanged" DisplayMemberPath="Title"></ComboBox>
        </StackPanel>

        <StackPanel Background="Black" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Width="200" Background="Red" Click="Button_Click">Сбросить</Button>
        </StackPanel>



        <ListView Grid.Row="3" Name="CityList" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal">
                    </WrapPanel>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                            <RowDefinition Height="auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding Title}"></TextBlock>
                        <Image Grid.Row="1" Width="250">
                            <Image.Source>
                                <Binding Path="Picture"></Binding>
                            </Image.Source>
                        </Image>
                        <TextBlock Grid.Row="2" Text="{Binding Population}"></TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
